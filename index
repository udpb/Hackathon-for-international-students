<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Solo &amp; Team Hackathon for International Students · 외국인 유학생을 위한 AI 해커톤 · Jun 6–7, 2026</title>
<meta name="description" content="2-country edge × AI × Korean startup visa. 2 days in Seoul (Sat 13:00 → Sun 13:00, no overnight stay). Hosted by underdogs × UD IMPACT. 두 시장 이해도와 AI로 만들고, OASIS 창업비자까지.">
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,700&amp;display=swap" rel="stylesheet">
<style>
:root {
  --action-orange: #FF8204;
  --orange2: #FFA40D;
  --orange3: #F05519;
  --primary-orange: #E8541A;
  --light-orange: #F0845A;
  --dark-charcoal: #373938;
  --dark2: #2D2D2D;
  --dark3: #1F2020;
  --warm-gray: #D8D4D7;
  --cyan: #06A9D0;
  --light-beige: #F5F0EB;
  --white: #FFFFFF;
  --body-text: #333333;
  --subtitle-text: #666666;
  --green: #2ECC71;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Poppins', sans-serif;
  color: var(--body-text);
  background: var(--white);
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ── Navigation ── */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 16px 32px;
  display: flex; align-items: center; justify-content: space-between;
  transition: all 0.3s ease;
}
.nav.scrolled {
  background: rgba(55, 57, 56, 0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,130,4,0.15);
  padding: 10px 32px;
}
.nav-brand { display: flex; align-items: center; gap: 12px; }
.nav-logo {
  font-weight: 700; font-style: italic; font-size: 20px;
  color: var(--white); letter-spacing: -0.5px;
}
.nav-badge {
  font-size: 10px; font-weight: 600;
  color: var(--action-orange); letter-spacing: 1.5px;
  padding: 3px 10px; border: 1px solid var(--action-orange);
}
.nav-links { display: flex; align-items: center; gap: 26px; }
.nav-links a {
  font-size: 13px; font-weight: 500;
  color: rgba(255,255,255,0.75); text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--action-orange); }
.nav-cta {
  font-size: 13px; font-weight: 700;
  color: var(--white); background: var(--primary-orange);
  padding: 11px 24px; text-decoration: none;
  transition: background 0.2s;
  letter-spacing: 0.3px;
}
.nav-cta:hover { background: var(--orange3); }
@media (max-width: 900px) { .nav-links > a { display: none; } }

/* ── HERO ── */
.hero {
  background: var(--dark-charcoal);
  min-height: 100vh;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
  padding: 120px 32px 60px;
}
.hero::before {
  content: ''; position: absolute; top: 0; right: 0;
  width: 55%; height: 100%;
  background: linear-gradient(135deg, transparent 40%, rgba(232,84,26,0.10) 100%);
  pointer-events: none;
}
.hero-quote-mark {
  position: absolute; right: -80px; bottom: -80px;
  font-size: 600px; font-weight: 700; font-style: italic;
  color: var(--primary-orange); opacity: 0.06;
  font-family: 'Poppins', sans-serif; line-height: 1;
  pointer-events: none;
}
.hero-accent-1 {
  position: absolute; bottom: 0; left: 8%; width: 320px; height: 3px;
  background: var(--action-orange); opacity: 0.4;
}
.hero-accent-2 {
  position: absolute; top: 18%; right: 6%; width: 2px; height: 180px;
  background: var(--action-orange); opacity: 0.25;
}
.hero-inner {
  max-width: 1200px; margin: 0 auto; width: 100%;
  position: relative; z-index: 2;
}
.hero-badge {
  display: inline-block;
  font-size: 11px; font-weight: 600;
  color: var(--action-orange); letter-spacing: 2px; text-transform: uppercase;
  border: 1px solid rgba(255,130,4,0.3);
  padding: 6px 16px; margin-bottom: 28px;
  animation: fadeInUp 0.6s ease both;
}
.hero h1 {
  font-size: clamp(40px, 6.5vw, 84px); font-weight: 700;
  color: var(--white); line-height: 1.04;
  letter-spacing: -2px; margin-bottom: 4px;
}
.hero h1 span { color: var(--action-orange); }
.hero h1:nth-of-type(1) { animation: fadeInUp 0.7s 0.1s ease both; }
.hero h1:nth-of-type(2) { animation: fadeInUp 0.7s 0.2s ease both; }
.hero h1:nth-of-type(3) { animation: fadeInUp 0.7s 0.3s ease both; }

.hero-h1-ko {
  font-size: clamp(16px, 2vw, 22px); font-weight: 500;
  color: rgba(255,255,255,0.75);
  margin-top: 22px;
  letter-spacing: -0.3px;
  animation: fadeInUp 0.7s 0.35s ease both;
}
.hero-subtitle {
  font-size: clamp(15px, 1.6vw, 17px); font-weight: 400;
  color: var(--warm-gray); max-width: 720px;
  line-height: 1.7; margin-top: 18px;
  animation: fadeInUp 0.7s 0.4s ease both;
}
.hero-subtitle-ko {
  font-size: clamp(13px, 1.4vw, 14px); font-weight: 400;
  color: rgba(216,212,215,0.5); max-width: 720px;
  line-height: 1.7; margin-top: 4px;
  animation: fadeInUp 0.7s 0.45s ease both;
}
.hero-ctas {
  display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
  margin-top: 40px;
  animation: fadeInUp 0.7s 0.5s ease both;
}
.btn-primary {
  font-size: 16px; font-weight: 700;
  color: var(--white); background: var(--primary-orange);
  padding: 18px 44px; text-decoration: none;
  transition: all 0.3s;
  display: inline-flex; align-items: center; gap: 10px;
  letter-spacing: 0.3px;
}
.btn-primary:hover {
  background: var(--orange3); transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(232,84,26,0.3);
}
.btn-secondary {
  font-size: 14px; font-weight: 500;
  color: var(--warm-gray); background: transparent;
  padding: 16px 28px; text-decoration: none;
  border: 1px solid rgba(216,212,215,0.3);
  transition: all 0.3s;
  display: inline-block;
}
.btn-secondary:hover {
  border-color: var(--action-orange); color: var(--action-orange);
}
.hero-cta-note {
  font-size: 12px; color: rgba(216,212,215,0.55);
  letter-spacing: 0.3px;
}
.hero-cta-note strong { color: var(--action-orange); font-weight: 700; }

.hero-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 32px; margin-top: 64px;
  padding-top: 36px;
  border-top: 1px solid rgba(255,255,255,0.08);
  animation: fadeInUp 0.7s 0.65s ease both;
}
.hero-stat-num {
  font-size: 22px; font-weight: 700;
  color: var(--action-orange); line-height: 1.15;
  letter-spacing: -0.3px;
}
.hero-stat-label {
  font-size: 11px; color: #999; margin-top: 8px;
  letter-spacing: 1px; text-transform: uppercase;
}
.hero-stat-label-ko {
  font-size: 11px; color: #666; margin-top: 3px;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(32px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Section Common ── */
section { padding: 96px 32px; position: relative; }
.container { max-width: 1200px; margin: 0 auto; }

.section-header { margin-bottom: 48px; }
.section-label {
  display: flex; align-items: center; gap: 10px;
  font-size: 11px; font-weight: 600;
  color: var(--primary-orange); letter-spacing: 2px; text-transform: uppercase;
  margin-bottom: 14px;
}
.section-label::before {
  content: ''; width: 10px; height: 10px; border-radius: 50%;
  background: var(--primary-orange); flex-shrink: 0;
}
.section-header h2 {
  font-size: clamp(28px, 4.2vw, 42px); font-weight: 700;
  color: var(--dark-charcoal); line-height: 1.2;
  letter-spacing: -1px; margin-bottom: 8px;
}
.section-header h3 {
  font-size: clamp(14px, 1.8vw, 17px); font-weight: 500;
  color: var(--subtitle-text); margin-bottom: 16px;
}
.section-header-divider {
  width: 60px; height: 3px; background: var(--primary-orange);
  margin-bottom: 20px;
}
.section-header p {
  font-size: 15px; color: var(--body-text);
  line-height: 1.75; max-width: 720px;
}
.section-header p.ko {
  font-size: 13px; color: var(--subtitle-text);
  margin-top: 6px;
}

section.dark { background: var(--dark-charcoal); }
section.dark .section-header h2 { color: var(--white); }
section.dark .section-header h3 { color: #999; }
section.dark .section-header p { color: var(--warm-gray); }
section.dark .section-header p.ko { color: #999; }
section.dark .section-label { color: var(--action-orange); }
section.dark .section-label::before { background: var(--action-orange); }
section.beige { background: var(--light-beige); }

/* ── Card Common ── */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2px;
}
.card {
  background: var(--white);
  padding: 36px 28px;
  border-top: 4px solid var(--primary-orange);
  transition: transform 0.3s;
}
.card:hover { transform: translateY(-4px); }

/* ── 3 PILLARS ── */
.pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
@media (max-width: 800px) { .pillars-grid { grid-template-columns: 1fr; } }
.pillar-card {
  background: var(--white);
  padding: 40px 32px;
  border-top: 4px solid;
  position: relative;
}
.pillar-card:nth-child(1) { border-top-color: var(--primary-orange); }
.pillar-card:nth-child(2) { border-top-color: var(--cyan); }
.pillar-card:nth-child(3) { border-top-color: var(--green); }
.pillar-num {
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.5px; margin-bottom: 18px;
}
.pillar-card:nth-child(1) .pillar-num { color: var(--primary-orange); }
.pillar-card:nth-child(2) .pillar-num { color: var(--cyan); }
.pillar-card:nth-child(3) .pillar-num { color: var(--green); }
.pillar-title {
  font-size: 24px; font-weight: 700;
  color: var(--dark-charcoal); margin-bottom: 4px;
  letter-spacing: -0.5px; line-height: 1.25;
}
.pillar-title-ko {
  font-size: 14px; font-weight: 600;
  color: var(--subtitle-text); margin-bottom: 18px;
}
.pillar-desc {
  font-size: 14px; color: var(--body-text);
  line-height: 1.75;
}
.pillar-desc-ko {
  font-size: 12px; color: var(--subtitle-text);
  line-height: 1.7; margin-top: 6px;
}

/* ── WHO ── */
.who-card {
  background: var(--dark-charcoal);
  color: var(--white);
  padding: 56px 48px;
  border-left: 4px solid var(--action-orange);
  margin-top: 24px;
}
@media (max-width: 700px) { .who-card { padding: 36px 28px; } }
.who-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px 32px;
  margin-bottom: 36px;
}
@media (max-width: 700px) { .who-grid { grid-template-columns: 1fr; } }
.who-item {
  padding: 6px 0 6px 32px;
  position: relative;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding-bottom: 12px;
}
.who-item::before {
  content: '✓';
  position: absolute; left: 0; top: 8px;
  color: var(--action-orange); font-weight: 700; font-size: 16px;
}
.who-item-en {
  font-size: 14px; font-weight: 500;
  color: var(--white); line-height: 1.4;
}
.who-item-ko {
  font-size: 12px; color: rgba(255,255,255,0.55);
  margin-top: 3px;
}
.who-cta-row {
  display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
  padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1);
}
.who-cta-row .btn-primary { padding: 14px 32px; font-size: 14px; }
.who-cta-note {
  font-size: 12px; color: rgba(255,255,255,0.55);
}

/* ── 4 EXAMPLES ── */
.models-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
}
@media (max-width: 800px) { .models-grid { grid-template-columns: 1fr; } }
.model-card {
  background: var(--white);
  padding: 32px 28px;
  border-top: 4px solid var(--primary-orange);
}
.model-card:nth-child(2) { border-top-color: var(--orange3); }
.model-card:nth-child(3) { border-top-color: var(--cyan); }
.model-card:nth-child(4) { border-top-color: var(--green); }
.model-num {
  font-size: 11px; font-weight: 700;
  color: var(--primary-orange); letter-spacing: 1.5px;
  margin-bottom: 14px;
}
.model-card:nth-child(2) .model-num { color: var(--orange3); }
.model-card:nth-child(3) .model-num { color: var(--cyan); }
.model-card:nth-child(4) .model-num { color: var(--green); }
.model-title {
  font-size: 19px; font-weight: 700;
  color: var(--dark-charcoal); margin-bottom: 2px;
  letter-spacing: -0.3px; line-height: 1.3;
}
.model-title-ko {
  font-size: 12px; color: var(--subtitle-text);
  margin-bottom: 16px;
}
.model-desc-en {
  font-size: 13px; color: var(--body-text);
  line-height: 1.7;
}
.model-desc-ko {
  font-size: 12px; color: var(--subtitle-text);
  line-height: 1.7; margin-top: 6px;
}
.model-case {
  margin-top: 14px; padding-top: 14px;
  border-top: 1px dashed #ddd;
  font-size: 12px; color: var(--body-text);
  line-height: 1.65;
}
.model-case strong {
  color: var(--primary-orange);
  font-weight: 700; font-size: 10px;
  letter-spacing: 1.5px; text-transform: uppercase;
  display: block; margin-bottom: 6px;
}
.model-case .case-ko {
  color: #999; font-size: 11px; display: block; margin-top: 2px;
}

/* ── ROADMAP JOURNEY ── */
.roadmap-journey {
  display: flex; gap: 0; margin-top: 16px;
  flex-wrap: wrap;
  background: var(--dark-charcoal); padding: 4px;
}
.roadmap-item {
  flex: 1; min-width: 160px;
  padding: 22px 24px;
  color: var(--white); font-size: 13px;
  position: relative;
}
.roadmap-item::after {
  content: '→';
  position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
  font-size: 20px; opacity: 0.4;
}
.roadmap-item:last-child::after { display: none; }
.roadmap-item .roadmap-stage {
  font-size: 10px; font-weight: 500;
  opacity: 0.7; margin-bottom: 4px;
  letter-spacing: 1px;
}
.roadmap-item .roadmap-date {
  font-size: 11px; font-weight: 600;
  opacity: 0.85; margin-bottom: 6px;
}
.roadmap-item .roadmap-name {
  font-size: 14px; font-weight: 700;
  letter-spacing: -0.3px;
}
.roadmap-item .roadmap-tag {
  font-size: 11px; margin-top: 4px; opacity: 0.85;
}

.outputs-row {
  margin-top: 48px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
}
@media (max-width: 800px) { .outputs-row { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 500px) { .outputs-row { grid-template-columns: 1fr; } }
.output-cell {
  background: var(--dark2);
  padding: 24px 20px;
  border-top: 2px solid var(--primary-orange);
}
.output-cell:nth-child(2) { border-top-color: var(--orange3); }
.output-cell:nth-child(3) { border-top-color: var(--cyan); }
.output-cell:nth-child(4) { border-top-color: var(--green); }
.output-label {
  font-size: 10px; font-weight: 700;
  color: var(--action-orange); letter-spacing: 1.5px;
  margin-bottom: 10px;
}
.output-cell:nth-child(2) .output-label { color: #FF9F66; }
.output-cell:nth-child(3) .output-label { color: var(--cyan); }
.output-cell:nth-child(4) .output-label { color: var(--green); }
.output-title {
  font-size: 14px; font-weight: 700;
  color: var(--white); line-height: 1.35;
  margin-bottom: 4px;
}
.output-title-ko {
  font-size: 11px; color: rgba(255,255,255,0.55);
}

/* ── SCHEDULE (Day 1 / Day 2) ── */
.sprint-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
}
@media (max-width: 700px) { .sprint-cards { grid-template-columns: 1fr; } }
.sprint-card {
  padding: 36px 32px;
  color: var(--white);
}
.sprint-card.accent { background: var(--primary-orange); }
.sprint-card.dark { background: var(--dark2); border-top: 2px solid var(--action-orange); }
.sprint-day {
  font-size: 11px; opacity: 0.8;
  letter-spacing: 1.5px; text-transform: uppercase;
  margin-bottom: 12px;
}
.sprint-title {
  font-size: 30px; font-weight: 700;
  letter-spacing: -0.5px; line-height: 1;
}
.sprint-title-ko {
  font-size: 13px; margin-top: 4px;
  margin-bottom: 20px;
}
.sprint-card.accent .sprint-title-ko { opacity: 0.85; }
.sprint-card.dark .sprint-title-ko { color: var(--action-orange); font-weight: 500; }
.sprint-list { list-style: none; padding: 0; }
.sprint-list li {
  padding: 8px 0;
  font-size: 13px; line-height: 1.5;
  border-bottom: 1px dashed rgba(255,255,255,0.15);
  display: flex; gap: 12px;
}
.sprint-card.accent .sprint-list li { border-color: rgba(255,255,255,0.2); }
.sprint-list li:last-child { border-bottom: none; }
.sprint-list .time {
  font-weight: 700; opacity: 0.85;
  font-size: 11px; letter-spacing: 0.5px;
  min-width: 70px; padding-top: 2px;
}
.sprint-list .task strong { display: block; font-weight: 600; }
.sprint-list .task .task-ko { font-size: 11px; opacity: 0.7; margin-top: 1px; }

/* ── LMS ── */
.lms-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 2px;
}
.lms-grid.lms-grid-3 {
  grid-template-columns: repeat(3, 1fr);
}
@media (max-width: 900px) { .lms-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 900px) { .lms-grid.lms-grid-3 { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 500px) { .lms-grid { grid-template-columns: 1fr; } }
@media (max-width: 500px) { .lms-grid.lms-grid-3 { grid-template-columns: 1fr; } }
.lms-cell {
  background: var(--white);
  padding: 26px 22px;
  border-top: 3px solid var(--primary-orange);
}
.lms-cell.featured { background: var(--primary-orange); }
.lms-cell.featured .lms-num,
.lms-cell.featured .lms-time { color: rgba(255,255,255,0.9); }
.lms-cell.featured .lms-name { color: var(--white); }
.lms-cell.featured .lms-name-ko { color: rgba(255,255,255,0.8); }
.lms-cell.featured .lms-desc { color: rgba(255,255,255,0.88); }
.lms-num {
  font-size: 12px; font-weight: 700;
  color: var(--primary-orange); letter-spacing: 1.5px;
  margin-bottom: 8px;
}
.lms-time {
  font-size: 11px; color: var(--subtitle-text);
  margin-bottom: 12px;
}
.lms-name {
  font-size: 15px; font-weight: 700;
  color: var(--dark-charcoal); margin-bottom: 2px;
  letter-spacing: -0.3px; line-height: 1.3;
}
.lms-name-ko {
  font-size: 11px; color: var(--subtitle-text);
  margin-bottom: 12px;
}
.lms-desc {
  font-size: 12px; color: var(--body-text);
  line-height: 1.6;
}

/* ── COACHING ── */
.coaching-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
@media (max-width: 700px) { .coaching-grid { grid-template-columns: 1fr; } }
.coaching-card {
  background: var(--white);
  padding: 32px 28px;
  border-top: 4px solid var(--primary-orange);
}
.coaching-card:nth-child(2) { border-top-color: var(--cyan); }
.coaching-card:nth-child(3) { border-top-color: var(--green); }
.coaching-week {
  font-size: 11px; font-weight: 700;
  color: var(--primary-orange); letter-spacing: 1.5px;
  margin-bottom: 12px;
}
.coaching-card:nth-child(2) .coaching-week { color: var(--cyan); }
.coaching-card:nth-child(3) .coaching-week { color: var(--green); }
.coaching-title {
  font-size: 18px; font-weight: 700;
  color: var(--dark-charcoal); margin-bottom: 2px;
  letter-spacing: -0.3px;
}
.coaching-title-ko {
  font-size: 12px; color: var(--subtitle-text);
  margin-bottom: 14px;
}
.coaching-desc {
  font-size: 13px; color: var(--body-text);
  line-height: 1.7;
}
.coaching-desc-ko {
  font-size: 11px; color: var(--subtitle-text);
  margin-top: 6px; line-height: 1.6;
